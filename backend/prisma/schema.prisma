generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")   ✅ THIS WILL WORK NOW
}

// User model (base for guest/staff/admin)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  role      Role     @default(GUEST)
  
  // Relations
  guest     Guest?
  staff     Staff?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

enum Role {
  GUEST
  STAFF
  ADMIN
}

// Guest model
model Guest {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Guest properties
  roomNumber       String?
  checkInDate      DateTime?
  checkOutDate     DateTime?
  preferences      Json?     // Store preferences like bedding, temperature, etc.
  loyaltyPoints    Int       @default(0)
  specialRequests  String?
  
  // Relations
  bookings         Booking[]
  requests         ServiceRequest[]
  feedback         Feedback[]
  chatSessions     ChatSession[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Staff model
model Staff {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  department       String
  position         String
  shift            String?
  isAvailable      Boolean  @default(true)
  assignedRequests ServiceRequest[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Booking model
model Booking {
  id               String   @id @default(cuid())
  guestId          String
  guest            Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  
  roomType         String
  checkInDate      DateTime
  checkOutDate     DateTime
  totalNights      Int
  totalPrice       Float
  status           BookingStatus @default(CONFIRMED)
  bookingRef       String   @unique
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([guestId, status])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

// Service Request model
model ServiceRequest {
  id               String   @id @default(cuid())
  guestId          String
  guest            Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  
  assignedStaffId  String?
  assignedStaff    Staff?   @relation(fields: [assignedStaffId], references: [id], onDelete: SetNull)
  
  category         String   // e.g., "Housekeeping", "Maintenance", "Room Service"
  description      String
  priority         Priority @default(NORMAL)
  status           RequestStatus @default(OPEN)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  completedAt      DateTime?

  @@index([guestId, status])
  @@index([assignedStaffId])
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum RequestStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Feedback model
model Feedback {
  id               String   @id @default(cuid())
  guestId          String
  guest            Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  
  rating           Int      // 1-5 scale
  text             String
  sentimentScore   Float?   // -1 to 1
  sentimentLabel   String?  // positive, neutral, negative
  keyPhrases       String[] // Extracted topics
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([guestId, sentimentLabel])
}

// Chat Session model
model ChatSession {
  id               String   @id @default(cuid())
  guestId          String
  guest            Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  
  title            String?
  messages         Json[]   // Store messages as JSON array
  context          Json?    // Store context/metadata
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([guestId, createdAt])
}